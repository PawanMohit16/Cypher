# Copy this file to .env and fill in your actual Pinata API keys
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET_API_KEY=

# Frontend/web3 configuration (Sepolia)
# Sepolia RPC URL, e.g. from Infura/Alchemy: https://sepolia.infura.io/v3/your-project-id
VITE_RPC_URL=
# Deployed CertVault contract address on Sepolia
VITE_CONTRACT_ADDRESS=
# Sepolia chain id: decimal (11155111) or hex (0xaa36a7)
VITE_CHAIN_ID=11155111

# Optional: Private key for scripts (NOT used by the frontend)
# Used by scripts/addAdmin.cjs
PRIVATE_KEY=

# Optional: override server port (defaults to 4000)
# PORT=4000
